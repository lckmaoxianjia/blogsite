generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Post {
  id          String     @id @db.VarChar(21)
  title       String     @db.VarChar(255)
  slug        String     @unique @db.VarChar(255)
  content     String     @db.MediumText
  excerpt     String?    @db.VarChar(500)
  coverImage  String?    @db.VarChar(500)
  status      PostStatus @default(DRAFT)
  viewCount   Int        @default(0)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  categories PostCategory[]
  comments   Comment[]

  @@index([status, publishedAt])
  @@fulltext([title, content])
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

model Category {
  id        String  @id @db.VarChar(21)
  name      String  @unique @db.VarChar(100)
  slug      String  @unique @db.VarChar(100)
  parentId  String? @db.VarChar(21)
  sortOrder Int     @default(0)

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  posts    PostCategory[]

  @@index([slug])
  @@index([parentId])
  @@index([sortOrder])
  @@map("Tag")
}

model PostCategory {
  postId     String   @db.VarChar(21)
  categoryId String   @map("tagId") @db.VarChar(21)
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
  @@map("PostTag")
}

model Comment {
  id            Int       @id @default(autoincrement())
  postId        String    @db.VarChar(21)
  authorName    String    @db.VarChar(100)
  authorEmail   String?   @db.VarChar(255)
  authorWebsite String?   @db.VarChar(500)
  content       String    @db.Text
  createdAt     DateTime  @default(now())
  isApproved    Boolean   @default(true)
  parentId      Int?

  post     Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentReplies")

  @@index([postId, createdAt])
}

model CarouselItem {
  id        String   @id @db.VarChar(21)
  imageUrl  String   @db.VarChar(500)
  linkUrl   String   @db.VarChar(500)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}
